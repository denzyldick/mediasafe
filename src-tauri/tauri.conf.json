{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Siegu",
  "version": "0.1.0",
  "identifier": "io.denzyl.siegu",
  "build": {
    "beforeDevCommand": "yarn dev -- --host",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Siegu",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' tauri: localhost; img-src 'self' data: tauri: asset: https: http://asset.localhost http://127.0.0.1:*; media-src 'self' tauri: asset: http://asset.localhost http://127.0.0.1:*; frame-src 'self' tauri: localhost; connect-src 'self' tauri: localhost ws: wss: https: http://127.0.0.1:*;",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "plugins": {
    "notification": {}
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "Privacy-first local media management.",
    "longDescription": "Siegu is a cross-platform, privacy-first media backup and synchronization application.",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "section": "Graphics"
      }
    }
  }
}